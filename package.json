{
  "name": "pulsechain-dashboard",
  "version": "2.1.1",
  "main": "./src/main.js",
  "author": "",
  "license": "ISC",
  "description": "Privacy-first PulseChain portfolio tracker",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },

  "dependencies": {
    "@pulsechainorg/gas-estimation": "^1.1.7",
    "axios": "^1.7.9",
    "call-bind": "^1.0.8",
    "ethers": "^5.7.2",
    "express": "^4.18.2",
    "isomorphic-git": "^1.29.0",
    "jotai": "^2.11.0",
    "js-sha3": "^0.9.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.1.0",
    "styled-components": "^6.1.13",
    "typeface-raleway": "^1.1.13",
    "web3": "^1.9.0"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-svgr": "^5.2.0"
  },

  "build": {
    "appId": "com.pulsechain-dashboard",
    "productName": "PulseChain Dashboard",
    "icon": "logo.ico",

    "directories": {
    "output": "dist_electron",
    "buildResources": "src/icons"
  },

    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js",
      "package.json"
    ],

    "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "logo.ico"
  }
  }
}